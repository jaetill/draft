{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::jaetill-game-nights",
        "arn:aws:s3:::jaetill-game-nights/*",
        "arn:aws:s3:::jaetill-meal-planner",
        "arn:aws:s3:::jaetill-meal-planner/*",
        "arn:aws:s3:::jaetill-carto",
        "arn:aws:s3:::jaetill-carto/*",
        "arn:aws:s3:::jaetill-portal",
        "arn:aws:s3:::jaetill-portal/*",
        "arn:aws:s3:::jaetill-draft",
        "arn:aws:s3:::jaetill-draft/*"
      ]
    }
  ]
}
